# Database - use the docker service name "mysql" as host
DATABASE_URL="mysql://root:YOUR_STRONG_PASSWORD@mysql:3306/makcom_ads"

# MySQL root password (must match DATABASE_URL)
MYSQL_ROOT_PASSWORD=YOUR_STRONG_PASSWORD

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://YOUR_SERVER_IP"

# Make.com webhooks
MAKE_SHARED_SECRET=""
MAKE_WEBHOOK_META_CONNECT=""
MAKE_WEBHOOK_META_LIST_ADACCOUNTS=""
MAKE_WEBHOOK_META_INSIGHTS=""
MAKE_WEBHOOK_CAMPAIGN_LIST=""
MAKE_WEBHOOK_CAMPAIGN_CREATE=""
MAKE_WEBHOOK_CAMPAIGN_UPDATE=""
MAKE_WEBHOOK_ADSET_LIST=""
MAKE_WEBHOOK_ADSET_CREATE=""
MAKE_WEBHOOK_AD_LIST=""
MAKE_WEBHOOK_AD_CREATE=""
MAKE_WEBHOOK_CREATIVE_CREATE=""
MAKE_WEBHOOK_IMAGE_UPLOAD=""
MAKE_WEBHOOK_VIDEO_UPLOAD=""

# App
APP_BASE_URL="http://YOUR_SERVER_IP"
